# Base URL of the FastAPI learning-engine backend (Tailscale HTTPS host).
#
# Leave blank to use the SAME ORIGIN the app is served from. This is the
# recommended setup: serve both the frontend and FastAPI behind the same
# Tailscale host (e.g. https://<tailscale-host>.ts.net) so no CORS / no
# public auth is required.
#
# Set it explicitly only if the backend lives on a different origin, e.g.:
#   PUBLIC_API_BASE_URL=https://alienware.tailnet-name.ts.net:8000
#
# Note: the value can also be overridden at runtime from the in-app Settings
# screen (stored in localStorage), which is handy for testing without a rebuild.
PUBLIC_API_BASE_URL=
