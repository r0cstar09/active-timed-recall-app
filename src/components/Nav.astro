---
import Glyph from "./Glyph.astro";
interface Props {
  current?: "home" | "verbs" | "lessons" | "misses" | "ingest" | "library" | "review" | "settings" | "passport";
}
const { current } = Astro.props;

const tabs = [
  { id: "home", href: "/", label: "Home", icon: "home" },
  { id: "verbs", href: "/verbs", label: "Verbs", icon: "verbs" },
  { id: "lessons", href: "/lessons", label: "Lessons", icon: "lessons" },
  { id: "misses", href: "/misses", label: "Review", icon: "misses" },
  { id: "passport", href: "/passport", label: "Passport", icon: "passport" },
  { id: "ingest", href: "/ingest", label: "Add", icon: "ingest" },
  { id: "library", href: "/library", label: "Library", icon: "library" },
  { id: "session", href: "/session", label: "Speak", icon: "session" },
  { id: "settings", href: "/settings", label: "Settings", icon: "settings" },
] as const;
---

<nav class="tabbar" aria-label="Primary">
  <div class="tabbar-inner">
    {tabs.map((t) => (
      <a class="tab" href={t.href} aria-current={current === t.id ? "page" : undefined}>
        <Glyph name={t.icon} />
        <span>{t.label}</span>
      </a>
    ))}
  </div>
</nav>
