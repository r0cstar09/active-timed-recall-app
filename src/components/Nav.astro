---
import Glyph from "./Glyph.astro";
interface Props {
  current?: "home" | "verbs" | "lessons" | "misses" | "ingest" | "library" | "review" | "settings" | "passport" | "session";
}
const { current } = Astro.props;

const primaryTabs = [
  { id: "home", href: "/", label: "Home", icon: "home" },
  { id: "lessons", href: "/lessons", label: "Lessons", icon: "lessons" },
  { id: "session", href: "/session", label: "Speak", icon: "session", cta: true },
  { id: "misses", href: "/misses", label: "Review", icon: "misses" },
  { id: "passport", href: "/passport", label: "Passport", icon: "passport" },
] as const;

const secondaryTabs = [
  { id: "verbs", href: "/verbs", label: "Verbs", icon: "verbs" },
  { id: "ingest", href: "/ingest", label: "Add", icon: "ingest" },
  { id: "library", href: "/library", label: "Library", icon: "library" },
  { id: "settings", href: "/settings", label: "Settings", icon: "settings" },
] as const;
const secondaryActive = secondaryTabs.some((t) => t.id === current);
---

<nav class="tabbar" aria-label="Primary">
  <div class="tabbar-inner tabbar-primary">
    {primaryTabs.map((t) => (
      <a class={`tab ${"cta" in t ? "tab-speak" : ""}`} href={t.href} aria-current={current === t.id ? "page" : undefined}>
        <Glyph name={t.icon} />
        <span>{t.label}</span>
      </a>
    ))}
    <details class="tab-more">
      <summary class="tab tab-more-trigger" aria-current={secondaryActive ? "page" : undefined}>
        <Glyph name="more" />
        <span>More</span>
      </summary>
      <div class="tab-more-menu">
        {secondaryTabs.map((t) => (
          <a class="tab-more-item" href={t.href} aria-current={current === t.id ? "page" : undefined}>
            <Glyph name={t.icon} />
            <span>{t.label}</span>
          </a>
        ))}
      </div>
    </details>
  </div>
</nav>
