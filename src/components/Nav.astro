---
/**
 * Bottom tab navigation (Astro component — static, no JS shipped).
 * `current` controls the active-tab highlight.
 */
interface Props {
  current?: "home" | "verbs" | "lessons" | "misses" | "ingest" | "library" | "review" | "settings";
}
const { current } = Astro.props;

const tabs = [
  { id: "home", href: "/", label: "Home" },
  { id: "verbs", href: "/verbs", label: "Verbs" },
  { id: "lessons", href: "/lessons", label: "Lessons" },
  { id: "misses", href: "/misses", label: "Review" },
  { id: "ingest", href: "/ingest", label: "Add" },
  { id: "library", href: "/library", label: "Library" },
  { id: "session", href: "/session", label: "Speak" },
  { id: "settings", href: "/settings", label: "Settings" },
];
---

<nav class="tabbar" aria-label="Primary">
  <div class="tabbar-inner">
    {
      tabs.map((t) => (
        <a
          class="tab"
          href={t.href}
          aria-current={current === t.id ? "page" : undefined}
        >
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            {t.id === "home" && (
              <>
                <path d="M3 10.5 12 3l9 7.5" />
                <path d="M5 9.5V21h14V9.5" />
              </>
            )}
            {t.id === "verbs" && (
              <>
                <path d="M5 4h14" />
                <path d="M7 8h10" />
                <path d="M8 12h8" />
                <path d="M10 16h4" />
              </>
            )}
            {t.id === "lessons" && (
              <>
                <path d="M4 5.5A2.5 2.5 0 0 1 6.5 3H20v16H6.5A2.5 2.5 0 0 0 4 21.5Z" />
                <path d="M4 5.5v16" />
                <path d="M8 7h8" />
                <path d="M8 11h6" />
              </>
            )}
            {t.id === "misses" && (
              <>
                <circle cx="12" cy="12" r="8" />
                <circle cx="12" cy="12" r="3" />
              </>
            )}
            {t.id === "ingest" && (
              <>
                <path d="M12 5v14" />
                <path d="M5 12h14" />
              </>
            )}
            {t.id === "library" && (
              <>
                <rect x="3" y="4" width="18" height="16" rx="2" />
                <path d="M3 9h18" />
              </>
            )}
            {t.id === "session" && (
              <>
                <rect x="9" y="3" width="6" height="11" rx="3" />
                <path d="M6 11a6 6 0 0 0 12 0" />
                <path d="M12 17v4" />
              </>
            )}
            {t.id === "review" && (
              <>
                <path d="M3 12a9 9 0 1 0 3-6.7" />
                <path d="M3 4v4h4" />
              </>
            )}
            {t.id === "settings" && (
              <>
                <circle cx="12" cy="12" r="3" />
                <path d="M19 12a7 7 0 0 0-.1-1.3l2-1.6-2-3.4-2.4 1a7 7 0 0 0-2.2-1.3L14 2h-4l-.3 2.4a7 7 0 0 0-2.2 1.3l-2.4-1-2 3.4 2 1.6A7 7 0 0 0 5 12c0 .4 0 .9.1 1.3l-2 1.6 2 3.4 2.4-1a7 7 0 0 0 2.2 1.3L10 22h4l.3-2.4a7 7 0 0 0 2.2-1.3l2.4 1 2-3.4-2-1.6c.1-.4.1-.9.1-1.3Z" />
              </>
            )}
          </svg>
          <span>{t.label}</span>
        </a>
      ))
    }
  </div>
</nav>
