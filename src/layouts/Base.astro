---
import "@fontsource-variable/fraunces";
import "@fontsource-variable/inter";
import "../styles/global.css";
import "../styles/daily-home.css";
import Nav from "../components/Nav.astro";
import { ClientRouter } from "astro:transitions";

interface Props {
  title?: string;
  heading?: string;
  current?: "home" | "verbs" | "lessons" | "misses" | "ingest" | "library" | "review" | "settings" | "session";
  /** Hide the bottom tab bar (used by the focused recall session screen). */
  hideNav?: boolean;
  /** Hide global shortcuts when the page supplies its own command surface. */
  hideCommandStrip?: boolean;
}
const {
  title = "Spanish Active Timed Recall",
  heading,
  current,
  hideNav = false,
  hideCommandStrip = false,
} = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="paper">
  <head>
    <meta charset="utf-8" />
    <script is:inline>
      (() => {
        try {
          const stored = localStorage.getItem("atr-theme");
          const prefersDark = window.matchMedia?.("(prefers-color-scheme: dark)").matches;
          const theme = stored || (prefersDark ? "dark" : "paper");
          document.documentElement.dataset.theme = theme;
        } catch {
          document.documentElement.dataset.theme = "paper";
        }
      })();
    </script>
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, viewport-fit=cover, maximum-scale=1"
    />
    <title>{title}</title>
    <meta name="description" content="Spanish acoustic-first active timed recall." />
    <meta property="og:title" content={title} />
    <meta property="og:description" content="Ear-first Spanish recall with focused lessons, spoken practice, and timer pressure." />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/og/spanish-recall-og.png" />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- PWA / iOS home-screen install -->
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#f6ead4" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#1a1410" media="(prefers-color-scheme: dark)" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Recall" />
    <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />
    <link rel="icon" href="/icons/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/icons/icon-192.png" sizes="192x192" type="image/png" />
    <link rel="apple-touch-startup-image" href="/splash/apple-splash-1170-2532.png" media="(device-width: 390px) and (device-height: 844px) and (-webkit-device-pixel-ratio: 3)" />
    <ClientRouter />
  </head>
  <body>
    <div class="pull-refresh" data-pull-refresh aria-live="polite" aria-hidden="true">
      <span class="pull-refresh__icon" aria-hidden="true">↓</span>
      <span class="pull-refresh__label">Pull to refresh</span>
    </div>
    <div class="app">
      <header class="app-header">
        <a class="brand" href="/">
          <img src="/icons/icon.svg" alt="" width="30" height="30" />
          <span>{heading ?? "Recall"}</span>
        </a>
        <div class="header-actions">
          <slot name="header-actions" />
          <button class="theme-toggle" type="button" data-theme-toggle aria-label="Toggle theme">☀︎</button>
        </div>
      </header>

      {!hideNav && !hideCommandStrip && (
        <section class="recall-command-strip" aria-label="Spanish recall shortcuts">
          <a href="/session"><span>⏱</span><strong>Session</strong><em>timed recall</em></a>
          <a href="/misses"><span>✦</span><strong>Misses</strong><em>FSRS queue</em></a>
          <a href="/lessons"><span>80</span><strong>Lessons</strong><em>pattern bank</em></a>
        </section>
      )}

      <main class="main">
        <slot />
      </main>
    </div>

    {!hideNav && <Nav current={current} />}

    <style is:global>
      .pull-refresh {
        --pull: 0px;
        align-items: center;
        color: var(--ink-muted, #76695d);
        display: flex;
        font: 700 0.78rem/1 var(--font-sans, system-ui, sans-serif);
        gap: 0.45rem;
        justify-content: center;
        left: 0;
        opacity: 0;
        pointer-events: none;
        position: fixed;
        right: 0;
        top: max(0.55rem, env(safe-area-inset-top));
        transform: translateY(calc(var(--pull) - 56px));
        transition: opacity 120ms ease, transform 120ms ease;
        z-index: 1000;
      }
      .pull-refresh.is-pulling,
      .pull-refresh.is-refreshing { opacity: 1; }
      .pull-refresh.is-ready .pull-refresh__icon { transform: rotate(180deg); }
      .pull-refresh__icon { font-size: 1.05rem; transition: transform 150ms ease; }
      .pull-refresh.is-refreshing .pull-refresh__icon { animation: pull-refresh-spin 650ms linear infinite; }
      @keyframes pull-refresh-spin { to { transform: rotate(360deg); } }
      @media (pointer: fine) { .pull-refresh { display: none; } }
      @media (prefers-reduced-motion: reduce) {
        .pull-refresh,
        .pull-refresh__icon { transition: none; }
        .pull-refresh.is-refreshing .pull-refresh__icon { animation: none; }
      }
    </style>

    <script>
      const updateThemeButton = () => {
        const button = document.querySelector("[data-theme-toggle]");
        if (!button) return;
        button.textContent = document.documentElement.dataset.theme === "dark" ? "Noche" : "Paper";
      };
      updateThemeButton();
      document.querySelector("[data-theme-toggle]")?.addEventListener("click", () => {
        const next = document.documentElement.dataset.theme === "dark" ? "paper" : "dark";
        document.documentElement.dataset.theme = next;
        localStorage.setItem("atr-theme", next);
        updateThemeButton();
      });

      // Register the non-intercepting service worker for installability.
      // It has NO fetch handler, so it never touches audio/media or /api
      // requests (acceptance test #11).
      if ("serviceWorker" in navigator) {
        window.addEventListener("load", () => {
          navigator.serviceWorker
            .register("/sw.js", { scope: "/" })
            .catch((err) => console.warn("SW registration failed:", err));
        });
      }

      const setupPullToRefresh = () => {
        const pullWindow = window as typeof window & { __pullRefreshCleanup?: () => void };
        pullWindow.__pullRefreshCleanup?.();
        const indicator = document.querySelector("[data-pull-refresh]");
        if (!(indicator instanceof HTMLElement) || !window.matchMedia("(pointer: coarse)").matches) return;

        const controller = new AbortController();
        const { signal } = controller;
        const threshold = 72;
        const label = indicator.querySelector(".pull-refresh__label");
        let startX = 0;
        let startY = 0;
        let pull = 0;
        let tracking = false;

        const reset = () => {
          tracking = false;
          pull = 0;
          indicator.classList.remove("is-ready", "is-pulling");
          indicator.style.setProperty("--pull", "0px");
          indicator.setAttribute("aria-hidden", "true");
          if (label) label.textContent = "Pull to refresh";
        };

        document.addEventListener("touchstart", (event) => {
          if (window.scrollY > 0 || event.touches.length !== 1) return;
          startX = event.touches[0].clientX;
          startY = event.touches[0].clientY;
          tracking = true;
        }, { passive: true, signal });

        document.addEventListener("touchmove", (event) => {
          if (!tracking || event.touches.length !== 1) return;
          const deltaX = event.touches[0].clientX - startX;
          const deltaY = event.touches[0].clientY - startY;
          if (deltaY <= 0 || Math.abs(deltaX) > deltaY || window.scrollY > 0) return reset();
          event.preventDefault();
          pull = Math.min(104, deltaY * 0.55);
          const ready = pull >= threshold;
          indicator.classList.add("is-pulling");
          indicator.classList.toggle("is-ready", ready);
          indicator.style.setProperty("--pull", `${pull}px`);
          indicator.setAttribute("aria-hidden", "false");
          if (label) label.textContent = ready ? "Release to refresh" : "Pull to refresh";
        }, { passive: false, signal });

        const finish = () => {
          if (!tracking) return;
          if (pull >= threshold) {
            tracking = false;
            indicator.classList.add("is-refreshing");
            if (label) label.textContent = "Refreshing…";
            window.location.reload();
          } else {
            reset();
          }
        };
        document.addEventListener("touchend", finish, { passive: true, signal });
        document.addEventListener("touchcancel", reset, { passive: true, signal });
        pullWindow.__pullRefreshCleanup = () => controller.abort();
      };

      setupPullToRefresh();
      document.addEventListener("astro:page-load", setupPullToRefresh);
    </script>
  </body>
</html>
