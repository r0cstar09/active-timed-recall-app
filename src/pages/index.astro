---
import Base from "../layouts/Base.astro";
import DueSummary from "../components/DueSummary.tsx";
---

<Base title="Spanish Active Timed Recall" heading="Spanish" current="home">
  <section class="hero-showpiece stack">
    <div class="hero-ambient hero-ambient-one" aria-hidden="true"></div>
    <div class="hero-ambient hero-ambient-two" aria-hidden="true"></div>

    <div class="hero-topline">
      <span>Spain → Latin America</span>
      <span>ear first</span>
      <span>timer pressure</span>
    </div>

    <div class="hero-stage">
      <div class="stack hero-copy-block">
        <div class="spanish-kicker">Train your ear</div>
        <h1>Make Spanish come out clean, fast, and alive.</h1>
        <p class="muted hero-copy">
          Castilian structure, Latin American rhythm, street-useful phrases — trained as spoken reps, not flashcard trivia.
        </p>
        <div class="hero-chips" aria-label="Spanish flavor map">
          <span>Madrid</span>
          <span>CDMX</span>
          <span>Medellín</span>
          <span>Buenos Aires</span>
          <span>San Juan</span>
        </div>
      </div>

      <div class="culture-card" aria-hidden="true">
        <div class="sun-disc"></div>
        <div class="route-line"><span></span><span></span><span></span><span></span></div>
        <div class="wave-stack"><i></i><i></i><i></i><i></i><i></i></div>
        <div class="culture-caption">habla / escucha / responde</div>
      </div>
    </div>
  </section>

  <DueSummary client:load />
</Base>
