---
import Base from "../layouts/Base.astro";
import DueSummary from "../components/DueSummary.tsx";
---

<Base title="Spanish Active Recall" heading="Spanish" current="home">
  <section class="card hero-card home-hero stack">
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="spanish-kicker">daily speaking ritual</div>
    <h1>Train your ear, then make Spanish come out fast.</h1>
    <p class="muted hero-copy">
      Hear the phrase. Understand the pattern. Remove the scaffold. Speak before the timer wins.
    </p>
    <div class="mosaic-strip" aria-hidden="true">
      <span></span><span></span><span></span><span></span><span></span><span></span>
    </div>
  </section>

  <DueSummary client:load />
</Base>
