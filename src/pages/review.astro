---
import Base from "../layouts/Base.astro";
import CorrectionReview from "../components/CorrectionReview.tsx";
---

<Base title="Review · Recall" heading="Review" current="review">
  <h1>Corrections</h1>
  <p class="muted">Failed cards with expected vs. your transcript and audio.</p>
  <div class="stack" style="margin-bottom: 16px;">
    <a class="btn btn-primary btn-block" href="/session?mode=misses">Practice misses workout</a>
    <p class="small faint" style="margin: 0;">Misses workout uses backend failed/partial items and does not update FSRS.</p>
  </div>
  <CorrectionReview client:load />
</Base>
